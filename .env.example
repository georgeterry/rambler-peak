# ---- Site ------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=https://www.ramblerpeak.com

# ---- Stripe ----------------------------------------------------------------
# Server-side only. Do NOT prefix with NEXT_PUBLIC.
STRIPE_SECRET_KEY=sk_test_replace_me
# Signing secret for the /api/webhooks/stripe endpoint. Get it from
# `stripe listen` (local) or the Dashboard webhook you create (production).
# Required in production; in dev the webhook skips verification if unset.
STRIPE_WEBHOOK_SECRET=whsec_replace_me
# Optional: pre-registered Stripe price IDs. If omitted, checkout uses
# inline price_data from /data/products.ts.
STRIPE_PRICE_DREAMLITE=
STRIPE_PRICE_PILLOW=

# ---- Transactional email + newsletter (Resend) -----------------------------
# Powers order confirmations, order notifications, the contact form, and
# newsletter signups. Without RESEND_API_KEY everything no-ops and logs
# (dev-safe). FROM must be on a domain you've verified in Resend.
RESEND_API_KEY=
EMAIL_FROM=Rambler Peak <hello@ramblerpeak.com>
CONTACT_TO_EMAIL=hello@ramblerpeak.com
# Create an Audience in Resend and paste its id — newsletter signups are added
# to it. Without it, signups just log (the customer still gets their code).
RESEND_AUDIENCE_ID=

# ---- Analytics (GA4 / Plausible) -------------------------------------------
NEXT_PUBLIC_ANALYTICS_ID=
